      "source": [
        "import torch\n",
        "import torchvision.models as models\n",
        "\n",
        "# Load AlexNet\n",
        "model = models.alexnet()\n",
        "\n",
        "# Count total parameters\n",
        "total_params = sum(p.numel() for p in model.parameters())\n",
        "\n",
        "print(\"Total number of parameters in AlexNet:\", total_params)\n"
      ]
    }
  ]
